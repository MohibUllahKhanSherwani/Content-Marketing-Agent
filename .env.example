# LLM
AZURE_OPENAI_MODE=real
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_API_VERSION=2024-06-01
CONTENT_AGENT_MODEL=azure/gpt-4o-mini
CONTENT_AGENT_REVIEW_MODEL=azure/gpt-4o

# Runtime
ENVIRONMENT=development
DATABASE_URL=sqlite:///./content_marketing_agent.db
CONNECTOR_DEFAULT_MODE=auto
ALLOW_REAL_PUBLISH=false
MONTHLY_TOKEN_BUDGET_USD=50
CREW_MAX_ITERATIONS=8
CREW_TASK_TIMEOUT_SECONDS=180
CREWAI_TRACING_ENABLED=false

# Optional search
SEARCH_MODE=mock
SERPER_API_KEY=

# WordPress
WORDPRESS_MODE=auto
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_DEFAULT_AUTHOR_ID=

# HubSpot
HUBSPOT_MODE=auto
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_BUSINESS_UNIT_ID=
HUBSPOT_EMAIL_TEMPLATE_PATH=

# LinkedIn
LINKEDIN_MODE=auto
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=

# Meta
META_MODE=auto
META_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=
META_AD_ACCOUNT_ID=

# Google Analytics 4
GA4_MODE=auto
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

