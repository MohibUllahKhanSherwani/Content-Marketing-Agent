# LLM
# Required for real LLM runs and /health/llm readiness:
GEMINI_API_MODE=real
GEMINI_API_KEY=

# Model selection — use the "provider/model-name" format understood by LiteLLM/CrewAI.
# Set these to any Gemini model you have access to.
#
# Gemini examples:
#   gemini/gemini-3.5-flash          (fast, cheap, latest flash)
#   gemini/gemini-2.0-flash-lite     (efficient, ideal for review)
#   gemini/gemini-2.0-flash          (high performance flash)
#   gemini/gemini-1.5-pro            (more capable, expert level reasoning)
#
# CONTENT_AGENT_MODEL       — used for high-volume drafting, summarization, and extraction.
# CONTENT_AGENT_REVIEW_MODEL — used for final editorial review and strategic quality checks.
CONTENT_AGENT_MODEL=gemini/gemini-3.5-flash
CONTENT_AGENT_REVIEW_MODEL=gemini/gemini-2.0-flash-lite

# Runtime
ENVIRONMENT=development
DATABASE_URL=sqlite:///./content_marketing_agent.db
CONNECTOR_DEFAULT_MODE=auto
ALLOW_REAL_PUBLISH=false
MONTHLY_TOKEN_BUDGET_USD=50
CREW_MAX_ITERATIONS=8
CREW_TASK_TIMEOUT_SECONDS=180
CREWAI_TRACING_ENABLED=false

# Optional search
SEARCH_MODE=mock
SERPER_API_KEY=

# WordPress
# Required for real WordPress draft creation (wp-draft-smoke / publish-draft real path):
WORDPRESS_MODE=auto
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_DEFAULT_AUTHOR_ID=

# HubSpot
HUBSPOT_MODE=auto
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_BUSINESS_UNIT_ID=
HUBSPOT_EMAIL_TEMPLATE_PATH=

# LinkedIn
LINKEDIN_MODE=auto
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=

# Meta
META_MODE=auto
META_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=
META_AD_ACCOUNT_ID=

# Google Analytics 4
GA4_MODE=auto
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=
